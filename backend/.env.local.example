# Local development — no Firebase or Supabase required.
# Copy to backend/.env and start the backend.
#
# 1. cp backend/.env.local.example backend/.env
# 2. uv run --directory backend alembic upgrade head
# 3. uv run --directory backend uvicorn app.main:app --reload --host 0.0.0.0 --port 8000

DATABASE_URL=sqlite+aiosqlite:///./dev.db
AUTH_PROVIDER=mock
EMAIL_PROVIDER=noop
EMAIL_FROM=dev@example.com
DASHBOARD_BASE_URL=http://localhost:3000
PUBLIC_SUBMIT_BASE_URL=http://localhost:8000
