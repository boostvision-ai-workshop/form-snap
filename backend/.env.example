# Backend Environment Variables
# Copy to .env:
#   cp .env.example .env

# Database (Supabase cloud Postgres)
DATABASE_URL=postgresql+asyncpg://user:password@db.xxx.supabase.co:6543/postgres

# Firebase Admin SDK
# Either set FIREBASE_SERVICE_ACCOUNT_JSON (inline JSON) or FIREBASE_CREDENTIALS_PATH (file path)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Application
PROJECT_NAME=Micro SaaS Backend
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
